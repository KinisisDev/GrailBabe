modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 18115
externalPort = 3003

[[ports]]
localPort = 18116
externalPort = 4200

[[ports]]
localPort = 22333
externalPort = 3000

[userenv]

[userenv.shared]
NODE_ENV = "production"
ENTRA_TENANT_ID = "0cd996b2-486d-4cb4-a256-43c14db68570"
ENTRA_CLIENT_ID = "c585acb9-882f-4886-87f4-e4335ddad620"
ENTRA_TENANT_SUBDOMAIN = "kinislabs"
VITE_ENTRA_TENANT_ID = "0cd996b2-486d-4cb4-a256-43c14db68570"
VITE_ENTRA_CLIENT_ID = "c585acb9-882f-4886-87f4-e4335ddad620"
VITE_ENTRA_TENANT_SUBDOMAIN = "kinislabs"
VITE_ENTRA_API_SCOPE = "api://c585acb9-882f-4886-87f4-e4335ddad620/access_as_user"
EXPO_PUBLIC_ENTRA_TENANT_ID = "0cd996b2-486d-4cb4-a256-43c14db68570"
EXPO_PUBLIC_ENTRA_CLIENT_ID = "c585acb9-882f-4886-87f4-e4335ddad620"
EXPO_PUBLIC_ENTRA_TENANT_SUBDOMAIN = "kinislabs"
EXPO_PUBLIC_ENTRA_API_SCOPE = "api://c585acb9-882f-4886-87f4-e4335ddad620/access_as_user"
