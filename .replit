modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 18115
externalPort = 3003

[[ports]]
localPort = 18116
externalPort = 4200

[[ports]]
localPort = 22333
externalPort = 3000

[userenv]

[userenv.shared]
NODE_ENV = "production"
ENTRA_TENANT_ID = "25284917-bc2d-4a04-b95c-26d7479c3ec3"
ENTRA_CLIENT_ID = "0c8a43d1-6dec-45b3-8c58-dbf8af12c373"
ENTRA_TENANT_SUBDOMAIN = "kinisiscustomer"
VITE_ENTRA_TENANT_ID = "25284917-bc2d-4a04-b95c-26d7479c3ec3"
VITE_ENTRA_CLIENT_ID = "0c8a43d1-6dec-45b3-8c58-dbf8af12c373"
VITE_ENTRA_TENANT_SUBDOMAIN = "kinisiscustomer"
VITE_ENTRA_API_SCOPE = "api://0c8a43d1-6dec-45b3-8c58-dbf8af12c373/access_as_user"
EXPO_PUBLIC_ENTRA_TENANT_ID = "25284917-bc2d-4a04-b95c-26d7479c3ec3"
EXPO_PUBLIC_ENTRA_CLIENT_ID = "0c8a43d1-6dec-45b3-8c58-dbf8af12c373"
EXPO_PUBLIC_ENTRA_TENANT_SUBDOMAIN = "kinisiscustomer"
EXPO_PUBLIC_ENTRA_API_SCOPE = "api://0c8a43d1-6dec-45b3-8c58-dbf8af12c373/access_as_user"
